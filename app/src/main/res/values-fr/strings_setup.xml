    <!-- Room check (ui/calibrate/CalibrateScreen.kt) -->
    <string name="room_intro">Une vérification rapide pour voir si l\'app entend ton jeu doux malgré les bruits de la pièce. Moins d\'une minute.</string>
    <string name="room_step1_title">Étape 1 : reste silencieux</string>
    <string name="room_step1_body">Ne joue pas. Laisse l\'app écouter le son normal de la pièce.</string>
    <string name="room_step1_label">Étape 1 : silence</string>
    <string name="room_transition_title">Prépare-toi à jouer DOUCEMENT</string>
    <string name="room_transition_sub">Ensuite : archet doux ou pincements légers</string>
    <string name="room_step2_label">Étape 2 : jeu doux</string>
    <string name="room_play_softly">joue doucement…</string>
    <string name="room_results">Résultats</string>
    <string name="room_verdict_good">Ta pièce est bien silencieuse</string>
    <string name="room_verdict_tight">Possible, mais un peu bruyant</string>
    <string name="room_verdict_overlap">Trop bruyant</string>
    <string name="room_explain_good">L\'app distingue facilement ton jeu du bruit de la pièce. Tout est prêt.</string>
    <string name="room_explain_tight">Les notes très douces risquent de ne pas être détectées ici. Une pièce plus calme serait encore mieux.</string>
    <string name="room_explain_overlap">L\'app ne distingue pas ton jeu doux du bruit de fond. Essaie une pièce plus calme.</string>
    <!-- %1$s = noise ceiling, %2$s = playing floor, %3$s = gate (pre-formatted levels) -->
