    <string name="sustain_best_time">best %1$s s</string>
    <string name="sustain_metric_in_tune">In tune</string>
    <string name="sustain_metric_steady">Steady</string>
    <string name="sustain_spot_on">spot on</string>
    <!-- %1$s = cents, pre-formatted ("12") -->
    <string name="sustain_cents_sharp">%1$s¢ sharp</string>
    <string name="sustain_cents_flat">%1$s¢ flat</string>
    <string name="sustain_rock_steady">rock steady</string>
