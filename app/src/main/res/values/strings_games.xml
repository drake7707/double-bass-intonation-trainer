<!-- The four game screens (ui/noteaccuracy, ui/sustain, ui/shift, ui/chords).
     game_ = shared between games; note_/sustain_/shift_/chords_ = per game.
     Everything shown mid-round obeys the distance-readability rule — keep translations short. -->
<resources>

    <!-- Shared across games -->
    <string name="game_quit">Quit round</string>
    <string name="game_listening">listening…</string>
    <string name="game_no_note">No note heard</string>
    <string name="game_wrong_note">wrong note?</string>
    <string name="game_wrong_octave">right note,\nwrong octave</string>
    <!-- Progress-dot accessibility descriptions; %1$d = note number -->
    <string name="game_dot_next">Note %1$d: next prompt</string>
    <string name="game_dot_pending">Note %1$d: pending</string>
    <string name="game_dot_missed">Note %1$d: missed</string>
    <string name="game_dot_perfect">Note %1$d: perfect</string>
    <string name="game_dot_close">Note %1$d: close</string>

    <!-- Find the Note -->
    <string name="note_play">Play</string>
    <!-- %1$s = average cents, pre-formatted ("12.4") -->
    <string name="note_avg_technical">average %1$s cents off</string>
    <!-- %1$s = mastery word (Locked in / Solid / Developing) -->
    <string name="note_how_in_tune">How in tune: %1$s</string>
