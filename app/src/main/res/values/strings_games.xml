    <!-- Shifts -->
    <string name="shift_start_on">Start on</string>
    <string name="shift_wrong_start">that\'s not it — start on</string>
    <string name="shift_then_go">then GO to</string>
    <string name="shift_hold">hold…</string>
    <string name="shift_go">GO —</string>
    <string name="shift_distance">shift distance</string>
    <string name="shift_confident">confident shift</string>
