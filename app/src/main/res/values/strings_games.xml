    <string name="note_pace_slower">Several prompts ran out of time — more breathing room keeps it fun.</string>
    <!-- %1$s = pace name (Calm/Steady/Quick/Swift) -->
    <string name="note_pace_switch">Switch to %1$s pace</string>

    <!-- Long Notes -->
    <string name="sustain_hold">Hold</string>
