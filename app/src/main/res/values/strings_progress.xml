    <string name="progress_intonation_compared">Intonation %1$s (last wk %2$s, %3$s %4$s)</string>
    <!-- %1$s = this-week cents -->
    <string name="progress_intonation_this_week">Intonation %1$s this week</string>
    <string name="progress_looser">looser</string>
    <string name="progress_tighter">tighter</string>
    <!-- %1$d = percent -->
    <string name="progress_pct_landed">%1$d%% notes landed</string>
    <string name="progress_pct_clean">%1$d%% clean</string>

    <string name="progress_accuracy_by_position">Accuracy by position</string>
    <string name="progress_keep_playing">keep playing</string>
    <!-- %1$s = avg cents, %2$d = sample count -->
