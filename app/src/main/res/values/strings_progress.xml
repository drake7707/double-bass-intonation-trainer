    <string name="progress_intonation_developing">Your notes are getting closer to in tune — keep practising!</string>

    <!-- Trend lines -->
    <string name="progress_trend_no_comparison">Keep playing to see how you improve each week.</string>
    <string name="progress_trend_tighter">That\'s more in tune than last week!</string>
    <string name="progress_trend_looser">A little off from last week — you\'ll get it back.</string>
    <string name="progress_trend_steady">About the same as last week.</string>

    <!-- Expert summary lines -->
    <plurals name="progress_rounds_count">
        <item quantity="one">1 round</item>
