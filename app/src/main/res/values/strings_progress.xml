<?xml version="1.0" encoding="utf-8"?>
<!-- Progress (progress_) and Achievements (ach_) screens.
     Achievement titles/descriptions are keyed by the achievement id (ach_<ID>_*), mapped in
     ui/common/Labels.kt achievementTitle/achievementDescription. The ids and emoji stay in the
     domain (game/Achievements.kt) — only the words are here. -->
<resources>

    <!-- Progress screen -->
    <string name="progress_title">Progress</string>
    <!-- Plain "Shifts" tab (Home only has the templated "Shifts — …") -->
    <string name="progress_tab_shifts">Shifts</string>
    <string name="progress_cd_achievements">Achievements</string>
    <!-- %1$d = unlocked, %2$d = total -->
    <string name="progress_ach_count">%1$d/%2$d</string>
    <string name="progress_done">Done</string>
    <string name="progress_no_rounds">No rounds yet</string>
    <string name="progress_no_rounds_sub">Play a game to see your progress here.</string>

    <string name="progress_stat_rounds">rounds</string>
    <string name="progress_stat_best">best</string>
    <string name="progress_stat_streak">day streak</string>
    <string name="progress_dash">—</string>

