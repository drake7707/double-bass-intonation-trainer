    <string name="room_step1_body">Don\'t play. Let the app listen to the room as it normally sounds.</string>
    <string name="room_step1_label">Step 1: stay quiet</string>
    <string name="room_transition_title">Get ready to play SOFTLY</string>
    <string name="room_transition_sub">Next: soft bowing or gentle plucks</string>
    <string name="room_step2_label">Step 2: soft playing</string>
    <string name="room_play_softly">play softly…</string>
    <string name="room_results">Results</string>
    <string name="room_verdict_good">Your room is nice and quiet</string>
    <string name="room_verdict_tight">Workable, but a bit loud</string>
    <string name="room_verdict_overlap">Too noisy</string>
    <string name="room_explain_good">The app can easily tell your playing from the room. You\'re all set.</string>
    <string name="room_explain_tight">Very soft notes might not register here. A quieter room works even better.</string>
    <string name="room_explain_overlap">The app can\'t tell your soft playing apart from the room\'s background noise. Try a quieter room.</string>
